# Public env vars (safe to ship) are prefixed EXPO_PUBLIC_ and read via app.config.js.
# Copy this file to .env and fill in real values. NEVER commit .env.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_REVENUECAT_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_KEY_ANDROID=
EXPO_PUBLIC_VEXO_API_KEY=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_STREAM_API_KEY=

# Build-time only (set as EAS secrets, not in the app bundle)
EAS_PROJECT_ID=
